
{
  "entities": {
    "Manual": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Manual",
      "type": "object",
      "description": "Represents a manual document.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Manual entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the manual."
        },
        "content": {
          "type": "string",
          "description": "The full content of the manual (e.g., Markdown or HTML)."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to Category."
        },
        "visibilityId": {
          "type": "string",
          "description": "Reference to VisibilityOption."
        },
        "summary": {
          "type": "string",
          "description": "AI-generated summary."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "content",
        "categoryId"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "VisibilityOption": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VisibilityOption",
      "type": "object",
      "description": "マニュアルの公開範囲（全社、部署限定など）を定義するエンティティ。",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "公開範囲の表示名（例：社外秘、全社公開）" },
        "color": { "type": "string", "description": "表示時のラベルカラー（HSLまたはTailwindカラー）" }
      },
      "required": ["id", "name"]
    },
    "HelpCenterArticle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HelpCenterArticle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "title", "content"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/categories/{categoryId}",
        "definition": { "entityName": "Category", "schema": { "$ref": "#/backend/entities/Category" }, "description": "カテゴリー情報" }
      },
      {
        "path": "/categories/{categoryId}/manuals/{manualId}",
        "definition": { "entityName": "Manual", "schema": { "$ref": "#/backend/entities/Manual" }, "description": "マニュアル情報" }
      },
      {
        "path": "/visibility_options/{optionId}",
        "definition": { "entityName": "VisibilityOption", "schema": { "$ref": "#/backend/entities/VisibilityOption" }, "description": "公開範囲の設定オプション" }
      },
      {
        "path": "/help_center_articles/{articleId}",
        "definition": { "entityName": "HelpCenterArticle", "schema": { "$ref": "#/backend/entities/HelpCenterArticle" }, "description": "ヘルプ記事" }
      }
    ]
  }
}
