
{
  "entities": {
    "Manual": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Manual",
      "type": "object",
      "description": "Represents a manual document.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Manual entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the manual."
        },
        "content": {
          "type": "string",
          "description": "The full content of the manual (e.g., Markdown or HTML)."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to Category."
        },
        "summary": {
          "type": "string",
          "description": "AI-generated summary."
        },
        "imageUrl": {
          "type": "string",
          "description": "Thumbnail image URL."
        },
        "description": {
          "type": "string",
          "description": "Short summary/description of the manual."
        },
        "categoryName": { "type": "string" },
        "lastUpdated": { "type": "string" },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "content",
        "categoryId"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/categories/{categoryId}",
        "definition": { "entityName": "Category", "schema": { "$ref": "#/backend/entities/Category" }, "description": "カテゴリー情報" }
      },
      {
        "path": "/categories/{categoryId}/manuals/{manualId}",
        "definition": { "entityName": "Manual", "schema": { "$ref": "#/backend/entities/Manual" }, "description": "マニュアル情報" }
      }
    ]
  }
}
